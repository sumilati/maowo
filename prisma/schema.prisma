// 猫窝 - 数据库 schema（多用户 + 多猫）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  cats          Cat[]
}

// 猫咪档案（属于某用户）
model Cat {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  breed     String?
  gender    String?
  birthday  String?
  neutered  Boolean  @default(true)
  bio       String?
  motto     String?
  avatar    String?
  traits    String   @default("[]")
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  diaries       Diary[]
  weightRecords WeightRecord[]
  healthRecords HealthRecord[]
  albumPhotos   AlbumPhoto[]
  milestones    Milestone[]
  messages      Message[]
  aiDiaries     AIDiary[]
  aiArtworks    AIArtwork[]
  imageCaptions ImageCaption[]
}

model Diary {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  date      DateTime
  title     String
  content   String
  mood      String?
  imageUrl  String?
  createdAt DateTime @default(now())
}

model WeightRecord {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  date      DateTime
  weight    Float
  note      String?
  createdAt DateTime @default(now())
}

model HealthRecord {
  id          String   @id @default(cuid())
  catId       String
  cat         Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  date        DateTime
  type        String
  title       String
  description String?
  nextDate    DateTime?
  createdAt   DateTime @default(now())
}

model AlbumPhoto {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  url       String
  title     String?
  tag       String?
  source    String   @default("upload")
  createdAt DateTime @default(now())
}

model Milestone {
  id          String   @id @default(cuid())
  catId       String
  cat         Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  date        DateTime
  title       String
  description String?
  icon        String?
  createdAt   DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  name      String
  content   String
  avatar    String?
  createdAt DateTime @default(now())
}

model AIDiary {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  keywords  String
  content   String
  createdAt DateTime @default(now())
}

model AIArtwork {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  prompt    String
  url       String
  style     String?
  createdAt DateTime @default(now())
}

model ImageCaption {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  imageUrl  String
  caption   String
  createdAt DateTime @default(now())
}
