// 猫窝 - 数据库 schema（多猫支持）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 猫咪档案（可有多只）
model Cat {
  id        String   @id @default(cuid())
  name      String
  breed     String?
  gender    String?
  birthday  String?
  neutered  Boolean  @default(true)
  bio       String?
  motto     String?
  avatar    String?
  traits    String   @default("[]") // JSON array of strings
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  diaries       Diary[]
  weightRecords WeightRecord[]
  healthRecords HealthRecord[]
  albumPhotos   AlbumPhoto[]
  milestones    Milestone[]
  messages      Message[]
  aiDiaries     AIDiary[]
  aiArtworks    AIArtwork[]
  imageCaptions ImageCaption[]
}

// 成长日记
model Diary {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  date      DateTime
  title     String
  content   String
  mood      String?
  imageUrl  String?
  createdAt DateTime @default(now())
}

// 体重记录
model WeightRecord {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  date      DateTime
  weight    Float
  note      String?
  createdAt DateTime @default(now())
}

// 健康记录（疫苗/驱虫/体检）
model HealthRecord {
  id          String   @id @default(cuid())
  catId       String
  cat         Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  date        DateTime
  type        String
  title       String
  description String?
  nextDate    DateTime?
  createdAt   DateTime @default(now())
}

// 相册
model AlbumPhoto {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  url       String
  title     String?
  tag       String?
  source    String   @default("upload")
  createdAt DateTime @default(now())
}

// 里程碑
model Milestone {
  id          String   @id @default(cuid())
  catId       String
  cat         Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  date        DateTime
  title       String
  description String?
  icon        String?
  createdAt   DateTime @default(now())
}

// 留言板（每只猫独立的留言）
model Message {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  name      String
  content   String
  avatar    String?
  createdAt DateTime @default(now())
}

// AI 第一人称日记
model AIDiary {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  keywords  String
  content   String
  createdAt DateTime @default(now())
}

// AI 艺术照
model AIArtwork {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  prompt    String
  url       String
  style     String?
  createdAt DateTime @default(now())
}

// 看图说话
model ImageCaption {
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  imageUrl  String
  caption   String
  createdAt DateTime @default(now())
}
